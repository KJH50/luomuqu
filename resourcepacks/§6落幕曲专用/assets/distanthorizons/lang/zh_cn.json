  "distanthorizons.config.common.lodBuilding.disableUnchangedChunkCheck.@tooltip":
    "禁用此检查可能会解决方块更改后LOD未更新的问题。",
  "distanthorizons.config.common.lodBuilding.pullLightingForPregeneratedChunks":
